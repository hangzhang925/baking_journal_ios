"recipe_import_ai.prompt.full" = "Please convert the baking recipe image or text I provide into JSON that Toastmark can import.\n\nOutput JSON only. Do not output Markdown, code fences, or explanations.\nUse schema: \"bready.recipe\" and schemaVersion: 1.\nUse numeric grams for all weights. Split time into duration.value and duration.unit; unit must be \"min\" or \"hr\". Split temperature into temperature.value and temperature.unit; unit must be \"F\" or \"C\".\nEvery ingredient must have a unique ingredientId. steps.materialAllocations may only reference those ingredientIds.\nPut uncertain information in notes. Do not invent precise weights.\n\nAllowed enums:\nkind: \"toast\", \"chiffon\", \"countryBread\", \"custom\"\ncategory: \"flour\", \"starter\", \"basic\", \"other\"\ntag: \"flour\", \"starter\", \"water\", \"salt\", \"sugar\", \"butter\", \"cream\", \"yeast\", \"egg\", \"other\"\nstep type: \"prep\", \"mixing\", \"fermentation\", \"rest\", \"shaping\", \"baking\", \"other\"\nproductionMethod: \"bake\", \"steam\"\n\nJSON shape:\n{\n  \"schema\": \"bready.recipe\",\n  \"schemaVersion\": 1,\n  \"recipe\": {\n    \"name\": \"Recipe name\",\n    \"kind\": \"custom\",\n    \"overallNotes\": \"Optional notes\",\n    \"ingredients\": [\n      {\n        \"ingredientId\": \"flour-1\",\n        \"name\": \"Bread flour\",\n        \"category\": \"flour\",\n        \"tag\": \"flour\",\n        \"weightGrams\": 500\n      }\n    ],\n    \"steps\": [\n      {\n        \"name\": \"Mix\",\n        \"type\": \"mixing\",\n        \"notes\": \"Step instructions\",\n        \"duration\": { \"value\": 20, \"unit\": \"min\" },\n        \"temperature\": { \"value\": 350, \"unit\": \"F\" },\n        \"productionMethod\": \"bake\",\n        \"materialAllocations\": [\n          { \"ingredientId\": \"flour-1\", \"percentage\": 100 }\n        ]\n      }\n    ]\n  }\n}";
